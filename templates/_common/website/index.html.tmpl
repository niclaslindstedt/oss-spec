<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="dark light" />

    <title>{{ name }}</title>
    <meta name="description" content="{{ description }}" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href="https://{{ name }}.example/" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <meta property="og:site_name" content="{{ name }}" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="{{ name }}" />
    <meta property="og:description" content="{{ description }}" />
    <meta property="og:url" content="https://{{ name }}.example/" />
    <meta property="og:image" content="https://{{ name }}.example/og-default.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="{{ name }} — {{ description }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ name }}" />
    <meta name="twitter:description" content="{{ description }}" />
    <meta name="twitter:image" content="https://{{ name }}.example/og-default.png" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "@id": "https://{{ name }}.example/#app",
        "name": "{{ name }}",
        "url": "https://{{ name }}.example/",
        "description": "{{ description }}",
        "applicationCategory": "DeveloperApplication",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
      }
    </script>
  </head>
  <body>
    <h1>{{ name }}</h1>
    <p>{{ description }}</p>
  </body>
</html>
